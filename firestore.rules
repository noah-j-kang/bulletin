rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: notes
    // Document ID: {noteId}
    // Fields:
    //   - id: string (required)
    //   - content: string (required, max 5000 chars)
    //   - x: number (required)
    //   - y: number (required)
    //   - color: string (required)
    //   - createdAt: number (required, immutable)
    //   - updatedAt: number (required)
    //   - authorId: string (required, immutable, matches auth.uid)
    //   - isGhost: bool (optional)
    //   - isArchived: bool (optional)
    //   - archivedAt: number (optional)
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required, immutable, matches userId)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - lastActive: number (required)
    //   - cursor: map (optional) { x: number, y: number }
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.authorId;
    }

    function isValidNote(data) {
      return data.keys().hasAll(['id', 'content', 'x', 'y', 'color', 'createdAt', 'updatedAt', 'authorId']) &&
             data.id is string &&
             data.content is string && data.content.size() <= 5000 &&
             data.x is number &&
             data.y is number &&
             data.color is string &&
             data.createdAt is number &&
             data.updatedAt is number &&
             data.authorId is string;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'lastActive']) &&
             data.uid is string &&
             data.lastActive is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /notes/{noteId} {
      allow read: if isAuthenticated();
      
      allow create: if isAuthenticated() && 
                      isValidNote(request.resource.data) &&
                      request.resource.data.authorId == request.auth.uid;
                      
      allow update: if isAuthenticated() && 
                      isValidNote(request.resource.data) &&
                      (isDocOwner() || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isArchived', 'archivedAt'])) &&
                      request.resource.data.authorId == resource.data.authorId &&
                      request.resource.data.createdAt == resource.data.createdAt;
                      
      allow delete: if isDocOwner();
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) && isValidUser(request.resource.data);
    }
  }
}
